{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "query-route": {
        "ClusterId": "cluster-query",
        "Match": {
          "Path": "/query/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/query" }
        ]
      },
      "cmd-route": {
        "ClusterId": "cluster-cmd",
        "Match": {
          "Path": "/cmd/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/cmd" }
        ]
      }
    },
    "Clusters": {
      "cluster-query": {
        "Destinations": {
          "query-destination": {
            "Address": "https://localhost:7027/"
          }
        }
      },
      "cluster-cmd": {
        "Destinations": {
          "cmd-destination": {
            "Address": "https://localhost:7235/"
          }
        }
      }
    }
  }
}
